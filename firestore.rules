rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection: anyone can read, authenticated or admin or public write allowed for management
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Categories collection: anyone can read, write allowed for management
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders collection: read and write allowed so customers can place and track orders
    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    // Users collection: read and write allowed for customer profile persistence
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Coupons collection: read by anyone, write allowed for admin panel management
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }

    // Banners collection: read by anyone, write allowed for admin panel management
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if true;
    }

    // Reviews collection: read by anyone, write allowed to post reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings collection: read by anyone, write allowed for admin panel updates
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
